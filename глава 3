import os
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from PIL import Image
import warnings
warnings.filterwarnings('ignore')

print("=" * 60)
print("ГЛАВА 3. АНАЛИЗ ИЗОБРАЖЕНИЙ (Forest Fire)")
print("=" * 60)

# ============================================================
# 1. ЗАГРУЗКА ДАТАСЕТА
# ============================================================

import kagglehub
path = kagglehub.dataset_download("datascientist97/forest-fire-dataset-binary-classification")
print(f"Датасет загружен: {path}")

# Поиск структуры
def find_images_dir(base_path):
    for root, dirs, files in os.walk(base_path):
        if 'fire' in dirs and 'nofire' in dirs:
            return root
    return None

images_dir = find_images_dir(path)
if images_dir:
    print(f"Найдена папка с изображениями: {images_dir}")
else:
    # Альтернативный поиск
    for item in os.listdir(path):
        item_path = os.path.join(path, item)
        if os.path.isdir(item_path):
            subdirs = os.listdir(item_path)
            if 'fire' in subdirs and 'nofire' in subdirs:
                images_dir = item_path
                break

if images_dir:
    train_dir = None
    for split in ['train', 'Train', 'training']:
        split_path = os.path.join(images_dir, split)
        if os.path.exists(split_path):
            train_dir = split_path
            break
    if not train_dir:
        train_dir = images_dir

# ============================================================
# 2. АНАЛИЗ КОЛИЧЕСТВА И БАЛАНСА КЛАССОВ
# ============================================================

print("\n" + "=" * 60)
print("АНАЛИЗ КОЛИЧЕСТВА И БАЛАНСА КЛАССОВ")
print("=" * 60)

if train_dir:
    fire_path = os.path.join(train_dir, 'fire')
    nofire_path = os.path.join(train_dir, 'nofire')
    
    fire_count = len([f for f in os.listdir(fire_path) if f.endswith(('.jpg','.png','.jpeg'))])
    nofire_count = len([f for f in os.listdir(nofire_path) if f.endswith(('.jpg','.png','.jpeg'))])
    
    print(f"Изображений класса 'fire': {fire_count}")
    print(f"Изображений класса 'nofire': {nofire_count}")
    print(f"Всего: {fire_count + nofire_count}")
    print(f"Баланс: {fire_count/(fire_count+nofire_count)*100:.1f}% / {nofire_count/(fire_count+nofire_count)*100:.1f}%")
    
    # Визуализация
    plt.figure(figsize=(6, 4))
    plt.bar(['fire', 'nofire'], [fire_count, nofire_count], color=['red', 'green'])
    plt.title('Распределение классов')
    plt.ylabel('Количество изображений')
    for i, v in enumerate([fire_count, nofire_count]):
        plt.text(i, v + 5, str(v), ha='center')
    plt.tight_layout()
    plt.show()
else:
    print("Не удалось найти структуру датасета")

# ============================================================
# 3. ПРИМЕРЫ ИЗОБРАЖЕНИЙ
# ============================================================

print("\n" + "=" * 60)
print("ПРИМЕРЫ ИЗОБРАЖЕНИЙ")
print("=" * 60)

if train_dir:
    fig, axes = plt.subplots(2, 4, figsize=(12, 6))
    classes = ['fire', 'nofire']
    
    for i, cls in enumerate(classes):
        cls_path = os.path.join(train_dir, cls)
        if os.path.exists(cls_path):
            images = [f for f in os.listdir(cls_path) if f.endswith(('.jpg','.png','.jpeg'))][:4]
            for j, img_name in enumerate(images):
                img_path = os.path.join(cls_path, img_name)
                img = Image.open(img_path)
                img.thumbnail((200, 200))
                axes[i, j].imshow(img)
                axes[i, j].set_title(f'{cls}')
                axes[i, j].axis('off')
    
    plt.tight_layout()
    plt.show()

# ============================================================
# 4. АНАЛИЗ РАЗРЕШЕНИЙ
# ============================================================

print("\n" + "=" * 60)
print("АНАЛИЗ РАЗРЕШЕНИЙ ИЗОБРАЖЕНИЙ")
print("=" * 60)

if train_dir:
    widths, heights = [], []
    for cls in ['fire', 'nofire']:
        cls_path = os.path.join(train_dir, cls)
        if os.path.exists(cls_path):
            images = [f for f in os.listdir(cls_path) if f.endswith(('.jpg','.png','.jpeg'))][:50]
            for img_name in images:
                img_path = os.path.join(cls_path, img_name)
                with Image.open(img_path) as img:
                    w, h = img.size
                    widths.append(w)
                    heights.append(h)
    
    if widths:
        print(f"Ширина: мин={min(widths)}, макс={max(widths)}, среднее={np.mean(widths):.0f}")
        print(f"Высота: мин={min(heights)}, макс={max(heights)}, среднее={np.mean(heights):.0f}")
        
        fig, axes = plt.subplots(1, 2, figsize=(12, 4))
        axes[0].hist(widths, bins=20, color='blue', alpha=0.7)
        axes[0].set_title('Распределение ширины')
        axes[1].hist(heights, bins=20, color='orange', alpha=0.7)
        axes[1].set_title('Распределение высоты')
        plt.tight_layout()
        plt.show()

