# 4.2. Выбросы по правилу 3-х сигм
print("\n4.2. Выбросы по правилу 3-х сигм:")
outliers_data = []
for col in sensor_cols:
    mean = df[col].mean()
    std = df[col].std()
    outliers = df[(df[col] < mean - 3*std) | (df[col] > mean + 3*std)]
    count = len(outliers)
    pct = count / len(df) * 100
    outliers_data.append([col, count, pct])
    print(f"   {col:20s}: {count:4d} выбросов ({pct:.2f}%)")

