def simple_lemmatize(text):
    """Упрощённая лемматизация для русского языка"""
    words = text.split()
    lemmatized = []
    for word in words:
        # Базовые правила для окончаний
        if word.endswith('ого') or word.endswith('его'):
            word = word[:-3]
        elif word.endswith('ому') or word.endswith('ему'):
            word = word[:-3]
        elif word.endswith('ыми') or word.endswith('ими'):
            word = word[:-3]
        elif word.endswith('ая') or word.endswith('яя'):
            word = word[:-2] + 'ий'
        elif word.endswith('ое') or word.endswith('ее'):
            word = word[:-2] + 'ий'
        elif word.endswith('ые') or word.endswith('ие'):
            word = word[:-2] + 'ый'
        elif word.endswith('ую') or word.endswith('юю'):
            word = word[:-2] + 'ый'
        elif word.endswith('ит'):
            word = word[:-2] + 'ить'
        elif word.endswith('ет'):
            word = word[:-2] + 'еть'
        elif word.endswith('ут') or word.endswith('ют'):
            word = word[:-2] + 'ть'
        lemmatized.append(word)
    return ' '.join(lemmatized)

