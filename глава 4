tfidf_search = TfidfVectorizer(stop_words=list(russian_stopwords))
search_matrix = tfidf_search.fit_transform(df_lem['clean_text'])

def search(query, top_n=3):
    query_vec = tfidf_search.transform([query])
    sim = cosine_similarity(query_vec, search_matrix).flatten()
    indices = sim.argsort()[-top_n:][::-1]
    return indices, sim[indices]

queries = [
    "спасибо отличный сервис",
    "ужасное обслуживание плохой товар"
]

for query in queries:
    indices, scores = search(query)
    print(f"\n🔍 Запрос: '{query}'")
    for i, (idx, score) in enumerate(zip(indices, scores), 1):
        text_preview = df_lem.iloc[idx]['text'][:70]
        if len(df_lem.iloc[idx]['text']) > 70:
            text_preview += "..."
        print(f"   {i}. Релевантность: {score:.3f} -> {text_preview}")
        print(f"      Тональность: {df_lem.iloc[idx]['sentiment']}")

